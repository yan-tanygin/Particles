<Window x:Class="CollidingParticles.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Colliding Particles" Height="720" Width="1200"
        Background="#101219" FontFamily="Cambria">
    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0E1017" Offset="0" />
            <GradientStop Color="#1A2230" Offset="0.5" />
            <GradientStop Color="#0E121B" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PanelBrush" Color="#1E2433" />
        <SolidColorBrush x:Key="AccentBrush" Color="#F2A65A" />
        <SolidColorBrush x:Key="AccentBrushSoft" Color="#F6C48C" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F1F2F5" />
        <SolidColorBrush x:Key="TextMuted" Color="#B6BCC8" />
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="#2A3347" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="24,20,24,12" Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Colliding Particles Lab" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="Elastic collisions with adjustable energy and density." FontSize="12" Foreground="{StaticResource TextMuted}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="StartPauseButton" Content="Pause" Click="StartPause_Click" Margin="0,0,12,0" />
                    <Button x:Name="ResetButton" Content="Reset" Click="Reset_Click" Background="#37435C" Margin="0,0,12,0" />
                    <Button x:Name="BurstButton" Content="Add Burst" Click="Burst_Click" Background="#243140" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Speed" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        <Slider x:Name="SpeedSlider" Minimum="0.25" Maximum="3" Value="1" Width="140" ValueChanged="SpeedSlider_OnValueChanged" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Restitution" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        <Slider x:Name="RestitutionSlider" Minimum="0.2" Maximum="1" Value="0.95" Width="140" ValueChanged="RestitutionSlider_OnValueChanged" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,0,24,24">
            <Border Background="#141924" CornerRadius="22" BorderBrush="#233046" BorderThickness="1">
                <Canvas x:Name="SimulationCanvas" ClipToBounds="True" />
            </Border>
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="18" Background="#2A3448" Padding="12" CornerRadius="12" Opacity="0.88">
                <TextBlock x:Name="StatsText" Foreground="{StaticResource TextPrimary}" FontSize="12" />
            </Border>
        </Grid>
    </Grid>
</Window>
